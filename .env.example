# Banco de Dados (Docker local)
DB_HOST=db
DB_PORT=3306
DB_NAME=sesmt_tse
DB_USER=sesmt
DB_PASS=your-strong-password-here

# Aplicacao
APP_NAME="SESMT - TSE Engenharia"
APP_URL=http://localhost:8080
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo

# Criptografia
AES_KEY=your-aes-key-here

# Email SMTP (vazio = desabilitado no ambiente de teste)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME="SESMT TSE"
SMTP_FROM_EMAIL=

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=application/pdf
